# Copy to secrets.env — NEVER upload secrets.env to public sites

TELEGRAM_BOT_TOKEN=your_token_from_BotFather
TELEGRAM_CHAT_ID=6407769605

# Oracle VM = primary | GitHub Actions = backup (set in workflow, not here)
CLOUD_ROLE=primary
BACKUP_STALE_MINUTES=25

# Faster scan on free cloud (50 stocks ~3 min, 97 stocks ~6 min)
STOCK_SCAN_LIMIT=100

# Optional AI note in alerts
# GROQ_API_KEY=your_groq_key
# AI_ENABLED=true

# Render web app — sync position/reports from private GitHub repo
# GITHUB_REPO=binaykumarjaiswal-ved/stock-analyst-cloud
# GITHUB_TOKEN=ghp_your_personal_access_token_with_repo_scope